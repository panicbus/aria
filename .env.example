# Copy this file to .env and fill in your values
# cp .env.example .env

# AI: Gemini (free tier at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=my_gemini_api_key
# Optional: override model (default gemini-2.5-flash). If 403, try gemini-1.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# News tab: AI summaries (scrape + Gemini). Free tier ~250–500 RPD; we cap at 3/fetch.
# ENABLE_AI_NEWS_SUMMARIES=false   # set to disable AI summaries (meta descriptions only)
# AI_NEWS_SUMMARIES_PER_FETCH=3    # max AI calls per 15-min fetch (default 3 → ~288/day)

# Phase 6a: Robinhood Crypto API — real portfolio data for BTC/ETH
# Generate at robinhood.com → Account → Settings → API (crypto)
# Optional: if not set, ARIA uses CoinGecko for prices and Portfolio tab shows unconfigured state
# ROBINHOOD_API_KEY=your_api_key_here
# Private key — Robinhood exports raw base64 (32 bytes). Either format works:
#   Raw base64 (what Robinhood gives you):
#   ROBINHOOD_PRIVATE_KEY=your_32byte_base64_key_here
#   Or PEM with \n for newlines:
#   ROBINHOOD_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMC4CAQ...\n-----END PRIVATE KEY-----"

# Display timezone for timestamps (chat context, etc.). Default: America/Los_Angeles
# TZ=America/Los_Angeles

# Optional: live stock prices + scanner company names. Free at https://finnhub.io
# FINNHUB_API_KEY=your-finnhub-key

# Phase 4: OHLCV historical data. Free at https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=your-alphavantage-key

# Web search (Tavily). Free tier: 1K searches/month. https://tavily.com
# TAVILY_API_KEY=tvly-your-key

# Evening briefing email (6pm weekdays). Requires SMTP.
# BRIEFING_EMAIL_TO=your@email.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=ARIA <your@gmail.com>
