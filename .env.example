# Copy this file to .env and fill in your values
# cp .env.example .env

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: for live stock prices (NVDA, AAPL). Free at https://finnhub.io
# FINNHUB_API_KEY=your-finnhub-key

# Phase 4: OHLCV historical data. Free at https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=your-alphavantage-key

# Web search (Tavily). Free tier: 1K searches/month. https://tavily.com
# TAVILY_API_KEY=tvly-your-key

# Evening briefing email (6pm weekdays). Requires SMTP.
# BRIEFING_EMAIL_TO=your@email.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=ARIA <your@gmail.com>
