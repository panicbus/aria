{
  "name": "aria",
  "version": "0.1.0",
  "description": "ARIA — Autonomous Research & Intelligence Assistant",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "predev": "lsof -ti:3001 | xargs kill -9 2>/dev/null || true",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "ts-node-dev --respawn --transpile-only server/index.ts",
    "build": "tsc && npm run build:server && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist-server/server/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.1.0",
    "recharts": "^2.12.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  }
}
